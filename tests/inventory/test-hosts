[nbp]
test-vm ansible_host=127.0.0.1 ansible_port=2222 ansible_user=debian

[uhubctl]
test-vm

[pig]
test-vm

# Pi NFS root provisioning — SSH to server as piroot (chroot wrapper shell)
[pi]
test-pi-nfs ansible_host=127.0.0.1 ansible_port=2222 ansible_user=piroot

# Live Pi verification — connects to running Pi via ProxyJump through server
[pi_live]
test-pi ansible_host=10.21.0.128 ansible_user=pi

[all:vars]
ansible_ssh_common_args=-o StrictHostKeyChecking=accept-new

# ProxyCommand (not ProxyJump) because OpenSSH's ProxyJump spawns a new ssh
# process that does NOT inherit the parent's -o IdentityFile option, so the
# jump-host auth fails under test. ProxyCommand lets us explicitly pass the
# key path via Ansible's templating.
[pi_live:vars]
ansible_ssh_common_args=-o StrictHostKeyChecking=accept-new -o ProxyCommand="ssh -i {{ ansible_ssh_private_key_file }} -W %h:%p -p 2222 -o StrictHostKeyChecking=accept-new debian@127.0.0.1"
