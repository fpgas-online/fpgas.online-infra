skip_list:
  - yaml[line-length]
  - name[missing]
  - name[play]
  - no-changed-when
  - command-instead-of-module
  - risky-shell-pipe
  - risky-file-permissions
  - fqcn[action-core]
  - role-name[path]

warn_list:
  - experimental

offline: true

exclude_paths:
  - .github/
  - ansible/switch.yml
