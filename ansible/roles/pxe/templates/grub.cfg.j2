# {{ ansible_managed }}
# GRUB config for QEMU aarch64 PXE test clients

set default=0
set timeout=3

{% for client in pxe_test_clients %}
menuentry "NFS Boot ({{ client.name }})" {
    linux /aarch64/vmlinuz root=/dev/nfs nfsroot={{ eth_local_address }}:{{ client.nfs_root }},nfsvers=3 ro ip=dhcp rootwait console={{ client.console }}
    initrd /aarch64/initrd.img
}
{% endfor %}
